<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Cocoar.Configuration</id>
    <version>1.0.0</version>
    <authors>Bernhard Windisch</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <icon>package-icon.png</icon>
    <readme>README.md</readme>
    <projectUrl>https://github.com/cocoar-dev/cocoar.configuration</projectUrl>
    <description>Lightweight, strongly-typed, deterministic multi-source configuration layering for .NET. Compose config from files, environment variables, HTTP endpoints and Microsoft IConfiguration sources with predictable last-write-wins merge semantics and atomic live recompute on changes.</description>
    <releaseNotes>Initial release: lightweight, strongly-typed, deterministic multi-source configuration layering with ordered last-write-wins merge and atomic recompute.</releaseNotes>
    <tags>configuration config settings json reactive csharp dotnet aspnetcore dependency-injection merge variables recompute</tags>
    <repository type="git" url="https://github.com/cocoar-dev/cocoar.configuration" commit="eed10fb03678c89c0736cf33fe85ec940518b66f" />
    <dependencies>
      <group targetFramework="net9.0">
        <dependency id="Microsoft.Extensions.DependencyInjection.Abstractions" version="9.0.6" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.Logging.Abstractions" version="9.0.0" exclude="Build,Analyzers" />
        <dependency id="System.Reactive" version="6.0.1" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>