  <dc:creator>Bernhard Windisch</dc:creator>
  <dc:description>Lightweight, strongly-typed, deterministic multi-source configuration layering for .NET. Compose config from files, environment variables, HTTP endpoints and Microsoft IConfiguration sources with predictable last-write-wins merge semantics and atomic live recompute on changes.</dc:description>
  <dc:identifier>Cocoar.Configuration</dc:identifier>
  <version>1.0.0</version>
  <keywords>configuration config settings json reactive csharp dotnet aspnetcore dependency-injection merge variables recompute</keywords>
